# Template for .env.prod -- the laptop-managed prod env file that deploy.ps1
# scp's to /etc/yg-license-server/yg-license-server.env on the GCP VM.
#
# Copy this to .env.prod (gitignored) and fill in. To bootstrap from an existing
# VM, run `./deploy.ps1 -ImportEnv` -- pulls the live env down so you don't
# have to type the current secrets by hand.
#
# To rotate every secret + push: `./deploy.ps1 -RotateSecrets`.

# Bearer token for /v1/admin/* and admin UI login.
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_TOKEN=

# Cookie signing key for the admin UI session. MUST be distinct from ADMIN_TOKEN.
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
SESSION_SECRET=

# At-rest encryption KEK (Fernet, urlsafe-base64 32 bytes). Wraps per-product
# private key + Stripe webhook secret + Stripe API key.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
LICENSE_KEY_ENCRYPTION_KEY=

# Previous KEK -- only set during a rotation. `deploy.ps1 -RotateSecrets`
# writes the old value here, then the operator runs
#   python -m app.scripts.rewrap_secrets --migrate-from-prev
# on the VM (or in a one-shot container), and finally clears this line and
# redeploys env. Steady state: empty.
LICENSE_KEY_ENCRYPTION_KEY_PREV=

# SQLite path inside the container (bind-mount target).
DATABASE_URL=sqlite:////data/license.db

# HTTPS-only cookies in prod (Caddy is in front).
COOKIE_SECURE=true

# Email (optional). Leave RESEND_API_KEY empty to disable.
RESEND_API_KEY=
EMAIL_FROM=onboarding@resend.dev

# Container image the systemd unit pulls + runs. deploy.ps1 builds new tags
# into ghcr.io; `systemctl restart` re-pulls :latest each time.
IMAGE=ghcr.io/why-gee/yg-license-server:latest

# Log output format. `text` (default) prints one-line human-readable records.
# `json` prints one JSON object per record (time, level, logger, message,
# request_id) -- right choice for Loki / Datadog / Cloud Logging ingestion.
LOG_FORMAT=text

# GCS bucket name for nightly DB backups (see deploy/gcp/backup.sh + the
# yg-license-backup.timer systemd unit). Auto-added by install.sh.
BACKUP_BUCKET=yglicenseserver-backups

# 32-byte hex secret — pepper for the BLAKE2b key hash. Must be stable
# for the lifetime of the deployment; rotating it requires re-issuing
# every license. Generate with:
#   python -c 'import secrets; print(secrets.token_hex(32))'
LICENSE_KEY_PEPPER=
