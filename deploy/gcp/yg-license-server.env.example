# Copy to /etc/yg-license-server/yg-license-server.env on the VM, then chmod 600.
# DO NOT commit a real copy of this file with secrets.

# Bearer token for /v1/admin/* and admin UI login.
# Generate: python -c "import secrets;print(secrets.token_urlsafe(32))"
ADMIN_TOKEN=

# Cookie signing key for the admin UI session. Use a separate value from ADMIN_TOKEN.
# Generate: python -c "import secrets;print(secrets.token_urlsafe(32))"
SESSION_SECRET=

# SQLite path inside the container. The /data dir is bind-mounted from the host.
DATABASE_URL=sqlite:////data/license.db

# Cookies require HTTPS once Caddy is fronting the app.
COOKIE_SECURE=true

# Email (1c). Leave RESEND_API_KEY empty to disable; sends are no-op'd.
RESEND_API_KEY=
EMAIL_FROM=onboarding@resend.dev

# Container image the systemd unit pulls + runs. install.sh writes a default
# (ghcr.io/why-gee/yg-license-server:latest) here if absent. deploy.ps1 builds
# new tags into ghcr.io and `systemctl restart` re-pulls :latest each time.
# Pin to a specific tag (e.g. :v0.3.1) for frozen-version SLA installs.
IMAGE=ghcr.io/why-gee/yg-license-server:latest

# ---- in-app backups (admin UI "Backups" page + app.scripts.run_backup) ----
# Local archive dir INSIDE the container; /data is the persistent volume.
BACKUP_DIR=/data/backups
# Optional S3-compatible destination; setting the bucket enables uploads.
# Endpoint empty = AWS S3; set for R2/MinIO/GCS-interop. Leave the key pair
# empty to use the ambient credential chain (instance profile etc.).
BACKUP_S3_BUCKET=
BACKUP_S3_ENDPOINT=
BACKUP_S3_REGION=
BACKUP_S3_ACCESS_KEY=
BACKUP_S3_SECRET_KEY=
BACKUP_S3_PREFIX=yg-license-server
# Retention for scheduled/manual archives (pre-restore_ snapshots are never
# auto-pruned). Keep N newest (0 = all); age cap in days (0 = none).
BACKUP_RETENTION_COUNT=14
BACKUP_RETENTION_DAYS=0
