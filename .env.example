# Local-dev .env. Copy to .env and fill in. .env is gitignored.
# start.ps1 reads this; it also re-validates required vars before launching.

# Bearer token for /v1/admin/* and admin UI login.
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_TOKEN=

# Cookie signing key for the admin UI session. MUST be a distinct value from
# ADMIN_TOKEN -- boot validator rejects equal values (rotation independence).
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
SESSION_SECRET=

# At-rest encryption KEK (Fernet, urlsafe-base64 32 bytes). Wraps the per-
# product Ed25519 private key + Stripe webhook secret + Stripe API key in
# the products table. Unset = no encryption (legacy / dev only).
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
LICENSE_KEY_ENCRYPTION_KEY=

# DB connection-pool tuning (Postgres only; ignored on sqlite).
# DB_POOL_SIZE=5
# DB_MAX_OVERFLOW=10
# DB_POOL_RECYCLE=1800

# Local SQLite. For Postgres use postgresql+psycopg://user:pass@host/db
DATABASE_URL=sqlite:///./license.db

# Cookies require HTTPS by default. For local http://localhost dev, set false.
COOKIE_SECURE=false

# Port the server listens on. Default 8540.
APP_PORT=8540

# Email (optional). Leave RESEND_API_KEY empty to disable email sends.
RESEND_API_KEY=
EMAIL_FROM=onboarding@resend.dev
